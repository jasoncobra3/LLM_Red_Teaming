# ============================================================
# LLM Red Teaming Platform - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- App Settings ---
APP_NAME="LLM Red Teaming Platform"
APP_SECRET_KEY="change-me-to-a-random-secret-key"
DATABASE_URL="sqlite:///./red_teaming.db"

# --- Auth (bcrypt-hashed passwords; generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'password', bcrypt.gensalt()).decode())")
AUTH_USERNAME="admin"
AUTH_PASSWORD_HASH=""

# --- OpenAI ---
OPENAI_API_KEY=""
OPENAI_ORG_ID=""

# --- Anthropic ---
ANTHROPIC_API_KEY=""

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME=""

# --- Google Gemini ---
GOOGLE_API_KEY=""

# --- AWS Bedrock ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION="us-east-1"

# --- HuggingFace ---
HUGGINGFACEHUB_API_TOKEN=""

# --- Groq ---
GROQ_API_KEY=""

# --- DeepSeek ---
DEEPSEEK_API_KEY=""
