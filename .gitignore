# Red Teaming Platform - Git Ignore

# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Local databases
*.db
*.sqlite3

# Logs
logs/
*.log

# Reports / generated artifacts
reports/generated/
reports/*.pdf
test_report.pdf
*.zip

# Streamlit secrets
.streamlit/secrets.toml

# Local telemetry/state
.deepeval/
.deepteam/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
